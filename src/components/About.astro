---
---

<!-- Who We Are – story + credentials accordion -->
<section class="story-section" id="about">
  <div class="story-inner">

    <!-- Left: project photo -->
    <div class="story-image-wrap">
      <img
        src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=900&q=80"
        alt="Ashaad Intelligent Technologies — server infrastructure and networking"
        loading="lazy"
        class="story-image"
      />
      <div class="story-image-badge">
        <span class="badge-number">Est.</span>
        <span class="badge-label">2018 — Zimbabwe</span>
      </div>
    </div>

    <!-- Right: company description -->
    <div class="story-content">
      <div class="section-label">Who We Are</div>

      <h2 class="story-heading">ASHAAD<br><span>INTELLIGENT</span><br>TECHNOLOGIES</h2>

      <p class="story-body">
        Founded in <strong>2018 in Zimbabwe</strong>, Ashaad Intelligent Technologies delivers cutting-edge digital infrastructure to homes, businesses and organisations across Southern Africa. Our solutions-driven approach pairs enterprise-grade technology with local insight and responsive support.
      </p>

      <p class="story-body">
        From CCTV surveillance and structured networking to full solar energy systems and IT protocol management, we provide the digital backbone that modern organisations depend on — across Zimbabwe, Mozambique and South Africa.
      </p>

      <!-- What we do -->
      <div class="story-services">
        <div class="story-services-label">What We Do</div>
        <ul class="story-services-list">
          <li>Digital Security &amp; CCTV</li>
          <li>Networking &amp; Structured Cabling</li>
          <li>IT Protocols &amp; Infrastructure</li>
          <li>Solar Systems &amp; Power Banks</li>
          <li>Access Control Systems</li>
          <li>Cloud &amp; Server Solutions</li>
          <li>Cybersecurity &amp; Helpdesk</li>
          <li>Fibre Optic &amp; Wireless</li>
        </ul>
      </div>

      <!-- Location chip -->
      <div class="story-location">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"/>
          <circle cx="12" cy="10" r="2.5"/>
        </svg>
        Harare, Zimbabwe — Serving Zimbabwe, Mozambique &amp; South Africa
      </div>

      <!-- Credentials accordion -->
      <div class="credentials-block">
        <button class="credentials-toggle" aria-expanded="false" aria-controls="credentials-panel">
          Regional Presence &amp; Key Facts <span class="credentials-chevron" aria-hidden="true">▼</span>
        </button>
        <div class="credentials-panel" id="credentials-panel" hidden>
          <ul class="credentials-list">
            <li>
              <span class="cred-label">Founded</span>
              <span class="cred-value">2018 — Harare, Zimbabwe</span>
            </li>
            <li>
              <span class="cred-label">Markets Served</span>
              <span class="cred-value">Zimbabwe, Mozambique, South Africa</span>
            </li>
            <li>
              <span class="cred-label">Core Services</span>
              <span class="cred-value">4 Major Divisions</span>
            </li>
            <li>
              <span class="cred-label">Support</span>
              <span class="cred-value">Mon–Sat 8:00AM – 6:00PM</span>
            </li>
            <li class="cred-policy">
              <span>Committed to Serving Mankind Through Technology</span>
            </li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Values: 4-card visual grid -->
<section class="values-section">
  <div class="values-label">
    <div class="section-label">What We Stand For</div>
  </div>
  <div class="values-grid">
    <div class="value-card" style="background-image: url('https://images.unsplash.com/photo-1551434678-e076c223a692?auto=format&fit=crop&w=700&q=80')">
      <div class="value-overlay"></div>
      <div class="value-content">
        <svg class="value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
          <circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <div class="value-name">Professionalism</div>
      </div>
    </div>

    <div class="value-card" style="background-image: url('https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=700&q=80')">
      <div class="value-overlay"></div>
      <div class="value-content">
        <svg class="value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <div class="value-name">Dedication</div>
      </div>
    </div>

    <div class="value-card" style="background-image: url('https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=700&q=80')">
      <div class="value-overlay"></div>
      <div class="value-content">
        <svg class="value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        <div class="value-name">Concentration</div>
      </div>
    </div>

    <div class="value-card" style="background-image: url('https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=700&q=80')">
      <div class="value-overlay"></div>
      <div class="value-content">
        <svg class="value-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="13 2 3 14 12 14 11 22 21 10 12 10"/>
        </svg>
        <div class="value-name">Innovation</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Story Section ────────────────────────────── */
  .story-section {
    background: var(--dark);
    padding: 80px 48px;
  }

  .story-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Image ───────────────────────────────────── */
  .story-image-wrap {
    position: relative;
    overflow: hidden;
    background: var(--charcoal);
    height: 560px;
  }

  .story-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .story-image-wrap:hover .story-image { transform: scale(1.04); }

  .story-image-badge {
    position: absolute;
    bottom: 24px;
    left: 24px;
    background: var(--orange);
    color: var(--dark);
    padding: 14px 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
  }

  .badge-number {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    line-height: 1;
  }

  .badge-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }

  /* ── Content ─────────────────────────────────── */
  .story-content {
    padding-top: 8px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .story-heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 4.5vw, 66px);
    line-height: 0.92;
    letter-spacing: 0.02em;
    margin-top: 16px;
  }

  .story-heading span { color: var(--orange); }

  .story-body {
    font-size: 14px;
    color: var(--ash);
    line-height: 1.85;
  }

  .story-body strong {
    color: var(--bone);
    font-weight: 400;
  }

  /* ── Services list ───────────────────────────── */
  .story-services {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 20px;
  }

  .story-services-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 14px;
  }

  .story-services-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
  }

  .story-services-list li {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: var(--bone);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .story-services-list li::before {
    content: '';
    display: block;
    width: 18px;
    height: 1px;
    background: var(--orange);
    flex-shrink: 0;
  }

  /* ── Location ────────────────────────────────── */
  .story-location {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.12em;
    color: var(--ash);
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 20px;
  }

  .story-location svg {
    width: 18px;
    height: 18px;
    color: var(--orange);
    flex-shrink: 0;
  }

  /* ── Credentials Accordion ───────────────────── */
  .credentials-block {
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 20px;
  }

  .credentials-toggle {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: 1px solid rgba(232,119,34,0.45);
    color: var(--orange);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    padding: 10px 20px;
    cursor: pointer;
    transition: background 0.25s, color 0.25s;
    width: 100%;
    justify-content: space-between;
  }

  .credentials-toggle:hover,
  .credentials-toggle[aria-expanded="true"] {
    background: var(--orange);
    color: var(--dark);
    border-color: var(--orange);
  }

  .credentials-chevron {
    font-size: 10px;
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .credentials-toggle[aria-expanded="true"] .credentials-chevron {
    transform: rotate(180deg);
  }

  .credentials-panel {
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s ease, opacity 0.3s ease;
    opacity: 0;
  }

  .credentials-panel.is-open {
    max-height: 400px;
    opacity: 1;
  }

  .credentials-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(255,255,255,0.07);
    margin-top: 12px;
  }

  .credentials-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    gap: 16px;
  }

  .cred-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ash);
  }

  .cred-value {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 0.1em;
    color: var(--bone);
    text-align: right;
  }

  .cred-policy { justify-content: flex-start !important; }

  .cred-policy span {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--orange);
  }

  /* ── Values 4-Card Grid ───────────────────────── */
  .values-section {
    padding: 80px 48px;
    background: var(--dark);
  }

  .values-label { margin-bottom: 40px; }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 4px;
    height: 380px;
  }

  .value-card {
    position: relative;
    background-size: cover;
    background-position: center;
    overflow: hidden;
  }

  .value-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17,16,16,0.6);
    transition: background 0.35s ease;
  }

  .value-card:hover .value-overlay { background: rgba(232,119,34,0.82); }

  .value-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    z-index: 2;
    padding: 24px;
  }

  .value-icon {
    width: 40px;
    height: 40px;
    color: var(--bone);
    transition: color 0.3s, transform 0.3s;
  }

  .value-card:hover .value-icon { color: var(--dark); transform: scale(1.1); }

  .value-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 30px;
    letter-spacing: 0.12em;
    color: var(--bone);
    transition: color 0.3s;
  }

  .value-card:hover .value-name { color: var(--dark); }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 1024px) {
    .story-inner { grid-template-columns: 1fr; gap: 40px; }
    .story-image-wrap { height: 400px; }
    .values-grid { height: auto; }
    .value-card { height: 220px; }
  }

  @media (max-width: 900px) {
    .story-section { padding: 60px 24px; }
    .values-section { padding: 60px 24px; }
    .values-grid { grid-template-columns: repeat(2, 1fr); height: auto; }
    .value-card { height: 200px; }
  }

  @media (max-width: 480px) {
    .story-image-wrap { height: 280px; }
    .story-services-list { grid-template-columns: 1fr; }
    .values-grid { grid-template-columns: 1fr 1fr; }
    .value-card { height: 160px; }
    .value-name { font-size: 24px; }
    .credentials-list li { flex-direction: column; align-items: flex-start; gap: 4px; }
    .cred-value { text-align: left; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.credentials-toggle');
    const panel  = document.getElementById('credentials-panel');
    if (!toggle || !panel) return;

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      if (expanded) {
        panel.classList.remove('is-open');
        panel.addEventListener('transitionend', () => { panel.hidden = true; }, { once: true });
      } else {
        panel.hidden = false;
        requestAnimationFrame(() => panel.classList.add('is-open'));
      }
    });
  });
</script>
