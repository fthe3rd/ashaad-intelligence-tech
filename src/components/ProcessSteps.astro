---
---

<section class="process-section" id="process">
  <div
    class="process-bg"
    style="background-image: url('/images/data-center.jpg')"
  ></div>
  <div class="process-overlay"></div>

  <div class="process-inner">
    <div class="section-label">Our Process</div>
    <h2 class="process-title">HOW WE <span>DELIVER</span></h2>

    <div class="process-steps">

      <div class="process-step">
        <div class="step-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <div class="step-num">01</div>
        <div class="step-name">Assessment</div>
      </div>

      <div class="step-arrow">→</div>

      <div class="process-step">
        <div class="step-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
        </div>
        <div class="step-num">02</div>
        <div class="step-name">Design</div>
      </div>

      <div class="step-arrow">→</div>

      <div class="process-step">
        <div class="step-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>
          </svg>
        </div>
        <div class="step-num">03</div>
        <div class="step-name">Installation</div>
      </div>

      <div class="step-arrow">→</div>

      <div class="process-step">
        <div class="step-icon-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
            <polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
        </div>
        <div class="step-num">04</div>
        <div class="step-name">Support</div>
      </div>

    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    padding: 120px 48px;
    overflow: hidden;
  }

  .process-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .process-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17,16,16,0.88);
  }

  .process-inner {
    position: relative;
    z-index: 2;
  }

  .process-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 7vw, 96px);
    line-height: 0.9;
    margin-top: 16px;
    margin-bottom: 80px;
  }

  .process-title span { color: var(--accent); }

  .process-steps {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .process-step {
    flex: 1;
    padding: 44px 28px;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(17,16,16,0.5);
    backdrop-filter: blur(4px);
    transition: background 0.3s, border-color 0.3s;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .process-step:hover {
    background: rgba(212,34,34,0.12);
    border-color: rgba(212,34,34,0.35);
  }

  .step-icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(212,34,34,0.35);
    background: rgba(212,34,34,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 8px;
    transition: background 0.3s, border-color 0.3s;
  }

  .process-step:hover .step-icon-wrap {
    background: rgba(212,34,34,0.2);
    border-color: var(--accent);
  }

  .step-icon-wrap svg {
    width: 24px;
    height: 24px;
    color: var(--accent);
  }

  .step-num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 52px;
    color: rgba(212,34,34,0.22);
    line-height: 1;
  }

  .step-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bone);
  }

  .step-arrow {
    font-size: 22px;
    color: rgba(212,34,34,0.4);
    display: flex;
    align-items: center;
    padding: 0 4px;
    flex-shrink: 0;
    align-self: center;
  }

  @media (max-width: 900px) {
    .process-section { padding: 80px 24px; }
    .process-bg { background-attachment: scroll; }
    .process-steps {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4px;
    }
    .step-arrow { display: none; }
    .process-step { padding: 32px 20px; }
    .process-title { margin-bottom: 48px; }
  }

  @media (max-width: 480px) {
    .process-steps { grid-template-columns: 1fr; }
  }
</style>
