---
---

<div class="pcta-strip">
  <a href="/contact" class="pcta-block">
    <div class="pcta-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </div>
    <div class="pcta-label">Sales Enquiry</div>
    <div class="pcta-sub">Request a tailored product quote</div>
    <span class="pcta-arrow">→</span>
  </a>

  <a href="/services" class="pcta-block">
    <div class="pcta-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
    </div>
    <div class="pcta-label">Our Services</div>
    <div class="pcta-sub">Installation &amp; support included</div>
    <span class="pcta-arrow">→</span>
  </a>

  <a href="/contact" class="pcta-block">
    <div class="pcta-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.64a16 16 0 0 0 5.9 5.9l1-1.02a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
    </div>
    <div class="pcta-label">Contact Us</div>
    <div class="pcta-sub">Talk to our technical team</div>
    <span class="pcta-arrow">→</span>
  </a>
</div>

<style>
  .pcta-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px;
    background: var(--charcoal);
  }

  .pcta-block {
    padding: 48px 40px;
    background: var(--dark);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    border-left: 3px solid transparent;
    transition: border-color 0.25s, background 0.25s;
    position: relative;
  }

  .pcta-block:hover {
    background: #161515;
    border-left-color: var(--orange);
  }

  .pcta-icon {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid rgba(232,119,34,0.35);
    background: rgba(232,119,34,0.06);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 6px;
  }

  .pcta-icon svg {
    width: 20px;
    height: 20px;
    color: var(--orange);
  }

  .pcta-label {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: var(--bone);
  }

  .pcta-sub {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--ash);
  }

  .pcta-arrow {
    position: absolute;
    bottom: 28px;
    right: 32px;
    font-size: 20px;
    color: rgba(232,119,34,0.4);
    transition: color 0.25s, transform 0.25s;
  }

  .pcta-block:hover .pcta-arrow {
    color: var(--orange);
    transform: translateX(4px);
  }

  @media (max-width: 900px) {
    .pcta-strip { grid-template-columns: 1fr; }
    .pcta-block { padding: 32px 24px; }
  }
</style>
