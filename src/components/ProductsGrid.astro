---
import { cameraProducts } from '../data/products.ts';
const products = cameraProducts.map(p => ({
  ...p,
  image: p.image ? `/images/cameras/${p.image}` : '',
}));
---

<section class="gallery-section">
  <!-- Filter buttons -->
  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">All</button>
    <button class="filter-btn" data-filter="hikvision">Hikvision</button>
    <button class="filter-btn" data-filter="dahua">Dahua</button>
    <button class="filter-btn" data-filter="bullet">Bullet</button>
    <button class="filter-btn" data-filter="turret">Turret</button>
    <button class="filter-btn" data-filter="dome">Dome</button>
  </div>

  <!-- Products grid -->
  <div class="gallery-grid" id="products-grid">
    {products.map(p => (
      <button
        class="product-card"
        data-brand={p.brand.toLowerCase()}
        data-category={p.category.toLowerCase()}
        data-id={p.id}
        aria-label={`View ${p.name} details`}
      >
        <div class="product-img-wrap">
          <img
            src={p.image}
            alt={p.name}
            loading="lazy"
            decoding="async"
          />
        </div>
        <div class="product-info-overlay">
          <div class="product-overlay-brand">{p.brand}</div>
          <div class="product-overlay-name">{p.name}</div>
          <span class="product-overlay-cta">View Details →</span>
        </div>
        <div class="product-footer">
          <span class="product-brand-tag">{p.brand}</span>
          <span class="product-category-tag">{p.badge}</span>
        </div>
      </button>
    ))}
  </div>
</section>

<!-- Lightbox dialogs -->
{products.map(p => (
  <dialog class="product-dialog" id={`dialog-${p.id}`}>
    <div class="dialog-inner">
      <button class="dialog-close" aria-label="Close">✕</button>
      <div class="dialog-layout">
        <div class="dialog-img-wrap">
          <img src={p.image} alt={p.name} />
        </div>
        <div class="dialog-content">
          <div class="dialog-brand">{p.brand}</div>
          <h2 class="dialog-title">{p.name}</h2>
          {p.model && <div class="dialog-model">Model: {p.model}</div>}
          <p class="dialog-desc">{p.description}</p>
          {p.features && p.features.length > 0 && (
            <div class="dialog-features">
              <div class="dialog-features-label">Key Features</div>
              <ul class="dialog-features-list">
                {p.features.map(f => <li>{f}</li>)}
              </ul>
            </div>
          )}
          <a href="/contact" class="btn-primary dialog-cta">Request a Quote</a>
        </div>
      </div>
    </div>
  </dialog>
))}

<script>
  // Filter logic
  const filterBtns = document.querySelectorAll('.filter-btn');
  const cards = document.querySelectorAll('.product-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = (btn as HTMLElement).dataset.filter!;
      cards.forEach(card => {
        const el = card as HTMLElement;
        const brand = el.dataset.brand!;
        const cat = el.dataset.category!;
        if (filter === 'all' || brand === filter || cat === filter) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  // Lightbox logic
  cards.forEach(card => {
    card.addEventListener('click', () => {
      const id = (card as HTMLElement).dataset.id!;
      const dialog = document.getElementById(`dialog-${id}`) as HTMLDialogElement | null;
      dialog?.showModal();
    });
  });

  document.querySelectorAll('.product-dialog').forEach(dialog => {
    const d = dialog as HTMLDialogElement;
    const closeBtn = d.querySelector('.dialog-close');
    closeBtn?.addEventListener('click', () => d.close());
    d.addEventListener('click', (e) => {
      if (e.target === d) d.close();
    });
  });
</script>

<style>
  .gallery-section {
    padding: 60px 48px 100px;
    background: var(--dark);
  }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 48px;
  }

  .filter-btn {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--ash);
    background: none;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 9px 20px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-btn:hover,
  .filter-btn.active {
    color: var(--dark);
    background: var(--orange);
    border-color: var(--orange);
  }

  /* ── Grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 4px;
  }

  .product-card {
    position: relative;
    background: var(--charcoal);
    border: none;
    cursor: pointer;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-align: left;
    padding: 0;
  }

  .product-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .product-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 16px;
    transition: transform 0.5s ease;
  }

  .product-card:hover .product-img-wrap img {
    transform: scale(1.05);
  }

  .product-info-overlay {
    position: absolute;
    inset: 0;
    background: rgba(232,119,34,0.9);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    opacity: 0;
    transition: opacity 0.3s ease;
    padding: 20px;
  }

  .product-card:hover .product-info-overlay { opacity: 1; }

  .product-overlay-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(17,16,16,0.7);
  }

  .product-overlay-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: var(--dark);
    text-align: center;
    line-height: 1.1;
  }

  .product-overlay-cta {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dark);
    border-bottom: 1px solid rgba(17,16,16,0.4);
    padding-bottom: 2px;
    margin-top: 8px;
  }

  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 16px;
    background: var(--charcoal);
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .product-brand-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ash);
  }

  .product-category-tag {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--orange);
    background: rgba(232,119,34,0.1);
    padding: 3px 10px;
    border: 1px solid rgba(232,119,34,0.25);
  }

  /* ── Dialog / Lightbox ── */
  .product-dialog {
    background: var(--charcoal);
    border: none;
    padding: 0;
    max-width: 920px;
    width: 92vw;
    max-height: 90vh;
    overflow-y: auto;
  }

  .product-dialog::backdrop {
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(4px);
  }

  .dialog-inner { position: relative; }

  .dialog-close {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(17,16,16,0.8);
    border: 1px solid rgba(255,255,255,0.1);
    color: var(--ash);
    font-size: 16px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: color 0.2s;
    line-height: 1;
  }

  .dialog-close:hover { color: var(--bone); }

  .dialog-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .dialog-img-wrap {
    background: #0a0a0a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    min-height: 360px;
  }

  .dialog-img-wrap img {
    max-width: 100%;
    max-height: 400px;
    object-fit: contain;
  }

  .dialog-content {
    padding: 44px 36px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dialog-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .dialog-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(24px, 3vw, 36px);
    letter-spacing: 0.05em;
    color: var(--bone);
    line-height: 1;
  }

  .dialog-model {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px;
    letter-spacing: 0.15em;
    color: var(--ash);
  }

  .dialog-desc {
    font-size: 13px;
    color: var(--ash);
    line-height: 1.8;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 16px;
  }

  .dialog-features { margin-top: 4px; }

  .dialog-features-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  .dialog-features-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .dialog-features-list li {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 0.06em;
    color: var(--bone);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dialog-features-list li::before {
    content: '';
    display: block;
    width: 16px;
    height: 1px;
    background: var(--orange);
    flex-shrink: 0;
  }

  .dialog-cta {
    margin-top: 8px;
    align-self: flex-start;
  }

  @media (max-width: 900px) {
    .gallery-section { padding: 40px 24px 80px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .dialog-layout { grid-template-columns: 1fr; }
    .dialog-img-wrap { min-height: 240px; padding: 24px; }
    .dialog-content { padding: 28px 24px; }
    .gallery-grid { grid-template-columns: 1fr; }
  }
</style>
