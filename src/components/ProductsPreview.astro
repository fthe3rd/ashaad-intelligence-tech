---
---

<section class="products-preview" id="products-preview">
  <div class="preview-header">
    <div class="section-label">Camera Solutions</div>
    <h2 class="preview-title">FEATURED <span>PRODUCTS</span></h2>
  </div>

  <div class="preview-grid">
    <a href="/products" class="preview-card preview-card--featured" style="background-image: url('/images/cameras/HikVision Fixed Turret Network Camera.png')">
      <div class="preview-overlay"></div>
      <div class="preview-info">
        <span class="preview-brand">Hikvision</span>
        <span class="preview-name">Full-Colour Night Vision Turret</span>
      </div>
    </a>

    <a href="/products" class="preview-card" style="background-image: url('/images/cameras/HikiVision Varifocal Bullet Camera.png')">
      <div class="preview-overlay"></div>
      <div class="preview-info">
        <span class="preview-brand">Hikvision</span>
        <span class="preview-name">Licence Plate Recognition</span>
      </div>
    </a>

    <a href="/products" class="preview-card" style="background-image: url('/images/cameras/Dahua Fixed-focal Bullet Camera.png')">
      <div class="preview-overlay"></div>
      <div class="preview-info">
        <span class="preview-brand">Dahua</span>
        <span class="preview-name">4K Outdoor Bullet Camera</span>
      </div>
    </a>

    <a href="/products" class="preview-card" style="background-image: url('/images/cameras/Dahua Motorized Vari-focal IR Dome Camera.png')">
      <div class="preview-overlay"></div>
      <div class="preview-info">
        <span class="preview-brand">Dahua</span>
        <span class="preview-name">4K Auto-Zoom Dome Camera</span>
      </div>
    </a>
  </div>

  <div class="preview-cta">
    <a href="/products" class="btn-ghost">View All Camera Products →</a>
  </div>
</section>

<style>
  .products-preview {
    padding: 100px 48px;
    background: var(--charcoal);
  }

  .preview-header { margin-bottom: 44px; }

  .preview-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 7vw, 96px);
    line-height: 0.9;
    margin-top: 16px;
  }

  .preview-title span { color: var(--orange); }

  .preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 4px;
  }

  .preview-card {
    position: relative;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--dark);
    text-decoration: none;
    overflow: hidden;
    display: block;
    height: 260px;
  }

  .preview-card--featured {
    grid-row: span 2;
    height: auto;
    min-height: 520px;
  }

  .preview-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(17,16,16,0.85) 0%, rgba(17,16,16,0.2) 60%, transparent 100%);
    transition: background 0.35s ease;
  }

  .preview-card:hover .preview-overlay {
    background: linear-gradient(to top, rgba(232,119,34,0.6) 0%, rgba(17,16,16,0.3) 60%, transparent 100%);
  }

  .preview-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px 22px;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .preview-brand {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
  }

  .preview-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bone);
    line-height: 1.3;
  }

  .preview-cta {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .products-preview { padding: 60px 24px; }
    .preview-grid { grid-template-columns: 1fr 1fr; }
    .preview-card--featured { grid-row: span 1; height: 240px; min-height: unset; }
    .preview-card { height: 200px; }
  }

  @media (max-width: 480px) {
    .preview-grid { grid-template-columns: 1fr; }
    .preview-card { height: 220px; }
  }
</style>
