---
const services = [
  {
    id: 'digital-security',
    name: 'Digital Security',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`,
    image: 'https://images.unsplash.com/photo-1557597774-9d273605dfa9?auto=format&fit=crop&w=600&q=70',
    href: '/services#digital-security',
  },
  {
    id: 'networking',
    name: 'Networking Solutions',
    icon: `<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>`,
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=600&q=70',
    href: '/services#networking',
  },
  {
    id: 'it-protocols',
    name: 'IT Protocols',
    icon: `<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>`,
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&w=600&q=70',
    href: '/services#it-protocols',
  },
  {
    id: 'solar',
    name: 'Solar Systems',
    icon: `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`,
    image: 'https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=600&q=70',
    href: '/services#solar',
  },
];
---

<section class="services-section" id="services">
  <div class="services-header">
    <div class="section-label">What We Deliver</div>
    <h2 class="services-title">OUR <span>SERVICES</span></h2>
  </div>

  <div class="services-grid">
    {services.map(s => (
      <a
        class="svc-card"
        href={s.href}
        style={`background-image: url('${s.image}')`}
        aria-label={s.name}
      >
        <div class="svc-overlay"></div>
        <div class="svc-content">
          <svg
            class="svc-icon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={s.icon}
          ></svg>
          <div class="svc-name">{s.name}</div>
          <span class="svc-arrow">→</span>
        </div>
      </a>
    ))}
  </div>

  <div class="services-cta">
    <a href="/services" class="btn-ghost">All Services →</a>
  </div>
</section>

<style>
  .services-section {
    padding: 100px 48px;
    background: var(--dark);
  }

  .services-header {
    margin-bottom: 44px;
  }

  .services-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 7vw, 96px);
    line-height: 0.9;
    margin-top: 16px;
  }

  .services-title span { color: var(--orange); }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  .svc-card {
    position: relative;
    height: 300px;
    background-size: cover;
    background-position: center;
    text-decoration: none;
    overflow: hidden;
    display: block;
  }

  .svc-overlay {
    position: absolute;
    inset: 0;
    background: rgba(17,16,16,0.68);
    transition: background 0.35s ease;
  }

  .svc-card:hover .svc-overlay {
    background: rgba(232,119,34,0.85);
  }

  .svc-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 14px;
    z-index: 2;
    padding: 20px;
  }

  .svc-icon {
    width: 38px;
    height: 38px;
    color: var(--bone);
    transition: color 0.3s, transform 0.3s;
  }

  .svc-card:hover .svc-icon {
    color: var(--dark);
    transform: scale(1.1) translateY(-4px);
  }

  .svc-name {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--bone);
    text-align: center;
    transition: color 0.3s;
    line-height: 1.3;
  }

  .svc-card:hover .svc-name { color: var(--dark); }

  .svc-arrow {
    font-size: 18px;
    color: var(--dark);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .svc-card:hover .svc-arrow {
    opacity: 1;
    transform: translateY(0);
  }

  .services-cta {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .services-section { padding: 60px 24px; }
    .svc-card { height: 240px; }
  }

  @media (max-width: 480px) {
    .services-grid { grid-template-columns: 1fr; }
    .svc-card { height: 200px; }
    .svc-name { font-size: 15px; }
  }
</style>
