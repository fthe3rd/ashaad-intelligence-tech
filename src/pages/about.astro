---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="About Us"
  description="Founded in 2018, Ashaad Intelligent Technologies delivers cutting-edge digital infrastructure across Zimbabwe, Mozambique and South Africa."
>

  <!-- ── Page Hero ──────────────────────────────── -->
  <section class="about-hero">
    <div class="about-hero-bg" style="background-image: url('https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1920&q=80')"></div>
    <div class="about-hero-overlay"></div>
    <div class="about-hero-content">
      <div class="about-hero-label">Who We Are</div>
      <h1 class="about-hero-title">ASHAAD INTELLIGENT<br><span>TECHNOLOGIES</span></h1>
      <p class="about-hero-sub">Built on purpose, driven by mission. Bringing the digital world to every family and every organisation across Southern Africa since 2018.</p>
    </div>
  </section>

  <!-- ── Story Section ──────────────────────────── -->
  <section class="about-story section">
    <div class="story-inner">
      <div class="story-text">
        <div class="section-label">Our Story</div>
        <h2 class="story-heading">BUILT ON<br><span>PURPOSE &amp;</span><br>MISSION</h2>
        <p>Ashaad Intelligent Technologies was founded in 2018 in Harare, Zimbabwe with a single mission: to make enterprise-grade digital infrastructure accessible to every organisation, large or small. From humble beginnings in CCTV installation, we grew into a full-spectrum technology company serving Zimbabwe, Mozambique and South Africa.</p>
        <p style="margin-top: 16px;">Our team combines local market knowledge with internationally-sourced equipment and best-practice deployment — delivering digital security, connectivity, clean power, and intelligent IT systems to clients who demand reliability.</p>
      </div>
      <div class="story-image">
        <img
          src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&w=900&q=80"
          alt="Digital infrastructure — network and connectivity"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- ── Regions & Credentials ─────────────────── -->
  <section class="accred-section">
    <div class="accred-inner">
      <div class="section-label">Where We Operate</div>
      <h2 class="accred-title">REGIONAL <span>PRESENCE</span></h2>
      <p class="accred-intro">Ashaad Intelligent Technologies operates across three countries in Southern Africa, delivering consistent technology solutions with local support in each market.</p>

      <div class="accred-grid">

        <!-- Zimbabwe -->
        <div class="accred-card">
          <div class="accred-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"/>
              <circle cx="12" cy="10" r="2.5"/>
            </svg>
          </div>
          <div class="accred-body">
            <div class="accred-label-text">Primary Market</div>
            <div class="accred-value">Zimbabwe</div>
            <div class="accred-desc">Headquartered in Harare, Zimbabwe. Our primary market since founding in 2018, serving residential, commercial and government clients nationwide.</div>
          </div>
        </div>

        <!-- Mozambique -->
        <div class="accred-card">
          <div class="accred-badge accred-badge--gold">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
            </svg>
          </div>
          <div class="accred-body">
            <div class="accred-label-text">Active Region</div>
            <div class="accred-value">Mozambique</div>
            <div class="accred-desc">Active operations in Maputo and surrounding areas. Delivering networking, solar and CCTV solutions to a growing base of Mozambican clients.</div>
          </div>
        </div>

        <!-- South Africa -->
        <div class="accred-card">
          <div class="accred-badge accred-badge--blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          </div>
          <div class="accred-body">
            <div class="accred-label-text">Active Region</div>
            <div class="accred-value">South Africa</div>
            <div class="accred-desc">Extending our reach into the South African market from Johannesburg. Supporting clients with enterprise security and infrastructure deployments.</div>
          </div>
        </div>

        <!-- Founded -->
        <div class="accred-card">
          <div class="accred-badge accred-badge--orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div class="accred-body">
            <div class="accred-label-text">Established</div>
            <div class="accred-value">Since 2018</div>
            <div class="accred-desc">Over six years of operations in Southern Africa, continuously expanding our service offerings and regional footprint to serve more clients.</div>
          </div>
        </div>

      </div>

      <div class="accred-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        <span>We respond to all enquiries within 24 hours. For urgent requirements, call us directly on +263 780 000 000 — Mon to Sat, 8:00 AM to 6:00 PM.</span>
      </div>
    </div>
  </section>

  <!-- ── CTA ────────────────────────────────────── -->
  <section class="about-cta">
    <h2 class="about-cta-title">Ready to Connect?</h2>
    <a href="tel:+263780000000" class="btn-call-about">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 1h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.64a16 16 0 0 0 5.9 5.9l1-1.02a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      Call Us Now
    </a>
  </section>

</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────── */
  .about-hero {
    min-height: 65vh;
    position: relative;
    display: flex;
    align-items: flex-end;
    padding: 0 80px 80px;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 40%;
  }

  .about-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(17,16,16,0.92) 0%,
      rgba(17,16,16,0.4) 60%,
      rgba(17,16,16,0.2) 100%
    );
  }

  .about-hero-content {
    position: relative;
    z-index: 2;
    max-width: 720px;
  }

  .about-hero-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .about-hero-label::before {
    content: '';
    display: block;
    width: 40px;
    height: 1px;
    background: var(--orange);
    flex-shrink: 0;
  }

  .about-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 7vw, 100px);
    line-height: 0.9;
    margin-bottom: 24px;
  }

  .about-hero-title span { color: var(--orange); }

  .about-hero-sub {
    font-size: 15px;
    line-height: 1.7;
    color: var(--ash);
    max-width: 500px;
  }

  /* ── Story ─────────────────────────────────────── */
  .about-story { background: var(--dark); }

  .story-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .story-heading {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 0.9;
    margin: 16px 0 32px;
  }

  .story-heading span { color: var(--orange); }

  .story-text p {
    font-size: 15px;
    line-height: 1.8;
    color: var(--ash);
  }

  .story-image {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .story-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Accreditations / Regions ─────────────────── */
  .accred-section {
    background: var(--charcoal);
    padding: 100px 48px;
  }

  .accred-inner { max-width: 1200px; }

  .accred-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 88px);
    line-height: 0.9;
    margin: 16px 0 24px;
  }

  .accred-title span { color: var(--orange); }

  .accred-intro {
    font-size: 15px;
    color: var(--ash);
    max-width: 560px;
    line-height: 1.7;
    margin-bottom: 60px;
  }

  .accred-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }

  .accred-card {
    background: var(--dark);
    padding: 40px 36px;
    display: flex;
    gap: 28px;
    align-items: flex-start;
    border-left: 3px solid transparent;
    transition: border-color 0.3s, background 0.3s;
  }

  .accred-card:hover {
    background: #1a1919;
    border-left-color: var(--orange);
  }

  .accred-badge {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .accred-badge svg {
    width: 24px;
    height: 24px;
    color: var(--ash);
  }

  .accred-badge--gold { background: rgba(218,165,32,0.1); border-color: rgba(218,165,32,0.3); }
  .accred-badge--gold svg { color: #daa520; }

  .accred-badge--blue { background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.3); }
  .accred-badge--blue svg { color: #60a5fa; }

  .accred-badge--orange { background: rgba(232,119,34,0.12); border-color: rgba(232,119,34,0.35); }
  .accred-badge--orange svg { color: var(--orange); }

  .accred-body { flex: 1; }

  .accred-label-text {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ash);
    margin-bottom: 8px;
  }

  .accred-value {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: var(--bone);
    margin-bottom: 10px;
  }

  .accred-desc {
    font-size: 13px;
    line-height: 1.65;
    color: var(--ash);
  }

  .accred-note {
    margin-top: 40px;
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 24px 28px;
    background: rgba(232,119,34,0.06);
    border: 1px solid rgba(232,119,34,0.15);
  }

  .accred-note svg {
    width: 18px;
    height: 18px;
    color: var(--orange);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .accred-note span {
    font-size: 13px;
    line-height: 1.65;
    color: var(--ash);
  }

  /* ── CTA ─────────────────────────────────────────── */
  .about-cta {
    background: var(--orange);
    padding: 80px 48px;
    text-align: center;
  }

  .about-cta-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 8vw, 100px);
    color: var(--dark);
    margin-bottom: 40px;
    line-height: 0.9;
  }

  .btn-call-about {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--bone);
    background: var(--dark);
    padding: 20px 52px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    clip-path: polygon(0 0, 100% 0, 100% 72%, 95% 100%, 0 100%);
  }

  .btn-call-about svg { width: 18px; height: 18px; }
  .btn-call-about:hover { background: #1a1a1a; transform: translateY(-3px); }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .about-hero { padding: 0 24px 60px; min-height: 55vh; }
    .story-inner { grid-template-columns: 1fr; gap: 40px; }
    .accred-section { padding: 60px 24px; }
    .accred-grid { grid-template-columns: 1fr; }
    .about-cta { padding: 60px 24px; }
  }
</style>
