---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with Ashaad Intelligent Technologies in Zimbabwe. Phone, email, or use our contact form."
>
  <section class="contact-page">
    <div class="page-bg"></div>
    <div class="page-grid"></div>

    <div class="contact-layout">
      <!-- Info panel -->
      <div class="contact-info">
        <div class="section-label">Get In Touch</div>
        <h1 class="contact-title">LET'S<br><span>TALK</span></h1>
        <p class="contact-intro">Ready to secure, connect, or power your organisation? Reach out to our team and we'll get back to you within 24 hours.</p>

        <div class="contact-details">
          <div class="contact-detail-item">
            <div class="detail-label">Phone</div>
            <a href="tel:+263780000000" class="detail-value">+263 780 000 000</a>
          </div>
          <div class="contact-detail-item">
            <div class="detail-label">Email</div>
            <a href="mailto:info@ashaadtech.co.zw" class="detail-value">info@ashaadtech.co.zw</a>
          </div>
          <div class="contact-detail-item">
            <div class="detail-label">Location</div>
            <div class="detail-value">Harare, Zimbabwe<br />Also serving Mozambique &amp; South Africa</div>
          </div>
          <div class="contact-detail-item">
            <div class="detail-label">Hours</div>
            <div class="detail-value">Mon – Sat: 8:00 – 18:00<br />Emergency enquiries welcome</div>
          </div>
        </div>
      </div>

      <!-- Form panel -->
      <div class="contact-form-panel">
        <div class="form-panel-header">
          <div class="section-label">Send a Message</div>
        </div>
        <ContactForm />
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq-section" itemscope itemtype="https://schema.org/FAQPage">
    <div class="faq-inner">
      <div class="faq-header">
        <div class="section-label">Frequently Asked Questions</div>
        <h2 class="faq-title">GOT <span>QUESTIONS?</span></h2>
        <p class="faq-subtitle">Everything you need to know about working with Ashaad Intelligent Technologies.</p>
      </div>

      <div class="faq-list">

        <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq-summary">
            <span itemprop="name">Where is Ashaad Intelligent Technologies located and what areas do you serve?</span>
          </summary>
          <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              <p>Ashaad Intelligent Technologies is headquartered in <strong>Harare, Zimbabwe</strong>. We serve clients across Zimbabwe and have active operations in <strong>Mozambique</strong> (Maputo) and <strong>South Africa</strong> (Johannesburg). Whether your project is local or regional, our teams can mobilise to deliver.</p>
            </div>
          </div>
        </details>

        <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq-summary">
            <span itemprop="name">What services does Ashaad Intelligent Technologies offer?</span>
          </summary>
          <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              <p>We provide four core technology services:</p>
              <ul>
                <li><strong>Digital Security</strong> — CCTV, access control, video analytics, alarms</li>
                <li><strong>Networking</strong> — structured cabling, fibre optic, wireless, enterprise switches</li>
                <li><strong>IT Protocols</strong> — servers, cloud, cybersecurity, helpdesk support</li>
                <li><strong>Solar Systems &amp; Power Banks</strong> — panels, battery storage, inverters, UPS</li>
              </ul>
            </div>
          </div>
        </details>

        <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq-summary">
            <span itemprop="name">Do you sell cameras and security equipment directly?</span>
          </summary>
          <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              <p>Yes. We supply <strong>Hikvision</strong> and <strong>Dahua</strong> camera products along with a full range of security and networking hardware. Browse our <a href="/products">camera products page</a> for an overview. We do not display prices publicly — contact us for a tailored quote based on your requirements.</p>
            </div>
          </div>
        </details>

        <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq-summary">
            <span itemprop="name">How do I get a quote for my project?</span>
          </summary>
          <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              <p>Getting started is straightforward:</p>
              <ul>
                <li>Fill in our <strong>contact form</strong> above — we respond within 24 hours</li>
                <li>Call us on <strong>+263 780 000 000</strong> (Mon–Sat, 8am–6pm)</li>
                <li>Email <strong>info@ashaadtech.co.zw</strong></li>
              </ul>
              <p>After your initial enquiry, one of our consultants will schedule a site assessment or consultation at your convenience.</p>
            </div>
          </div>
        </details>

        <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
          <summary class="faq-summary">
            <span itemprop="name">Do you provide after-installation support and maintenance?</span>
          </summary>
          <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text">
              <p>Yes. All our installations come with post-installation support. We offer <strong>maintenance contracts</strong> for security systems, network infrastructure, and solar installations — covering regular health checks, firmware updates, and responsive fault resolution. Contact us to discuss a support package suited to your system.</p>
            </div>
          </div>
        </details>

      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Contact Page ─────────────────────────────── */
  .contact-page {
    min-height: 100vh;
    padding: 140px 48px 100px;
    position: relative;
    overflow: hidden;
  }
  .page-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 80% 20%, rgba(232,119,34,0.06) 0%, transparent 60%),
      linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0d0d0d 100%);
  }
  .page-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(232,119,34,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,119,34,0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 75%);
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative; z-index: 2;
  }
  .contact-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(60px, 8vw, 100px);
    line-height: 0.9;
    margin-bottom: 24px;
  }
  .contact-title span { color: var(--orange); }
  .contact-intro {
    font-size: 15px;
    color: var(--ash);
    line-height: 1.8;
    margin-bottom: 48px;
    max-width: 380px;
  }
  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .contact-detail-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .detail-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--orange);
  }
  .detail-value {
    font-size: 15px;
    color: var(--bone);
    line-height: 1.6;
    text-decoration: none;
    transition: color 0.2s;
  }
  a.detail-value:hover { color: var(--orange); }
  .form-panel-header { margin-bottom: 32px; }

  /* ── FAQ Section ──────────────────────────────── */
  .faq-section {
    background: var(--charcoal);
    padding: 100px 48px;
  }
  .faq-inner {
    max-width: 900px;
    margin: 0 auto;
  }
  .faq-header {
    margin-bottom: 56px;
  }
  .faq-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(48px, 6vw, 80px);
    line-height: 0.92;
    margin-top: 16px;
    margin-bottom: 16px;
  }
  .faq-title span { color: var(--orange); }
  .faq-subtitle {
    font-size: 14px;
    color: var(--ash);
    line-height: 1.8;
    max-width: 520px;
  }

  /* ── FAQ Accordion ────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(255,255,255,0.08);
  }

  .faq-item {
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .faq-summary {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    padding: 24px 0;
    cursor: pointer;
    color: var(--bone);
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(15px, 2vw, 18px);
    letter-spacing: 0.04em;
    transition: color 0.2s;
    user-select: none;
  }
  .faq-summary::-webkit-details-marker { display: none; }

  .faq-summary::after {
    content: '▼';
    font-size: 11px;
    color: var(--orange);
    flex-shrink: 0;
    transition: transform 0.3s ease;
    display: inline-block;
  }

  .faq-summary:hover { color: var(--orange); }
  .faq-item[open] > .faq-summary { color: var(--orange); }
  .faq-item[open] > .faq-summary::after { transform: rotate(180deg); }

  .faq-answer {
    padding-bottom: 24px;
  }

  .faq-answer p {
    font-size: 14px;
    color: var(--ash);
    line-height: 1.85;
    margin-bottom: 12px;
  }
  .faq-answer p:last-child { margin-bottom: 0; }

  .faq-answer ul {
    list-style: none;
    padding: 0;
    margin: 10px 0 14px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .faq-answer ul li {
    font-size: 13px;
    color: var(--bone);
    padding-left: 20px;
    position: relative;
    line-height: 1.6;
  }
  .faq-answer ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--orange);
  }
  .faq-answer a {
    color: var(--orange);
    text-decoration: none;
    border-bottom: 1px solid rgba(232,119,34,0.3);
    transition: border-color 0.2s;
  }
  .faq-answer a:hover { border-color: var(--orange); }

  /* ── Responsive ───────────────────────────────── */
  @media (max-width: 900px) {
    .contact-page { padding: 120px 24px 80px; }
    .contact-layout { grid-template-columns: 1fr; gap: 48px; }
    .faq-section { padding: 60px 24px; }
    .faq-summary { padding: 20px 0; }
  }
</style>
