---
import Layout from '../layouts/Layout.astro';

const offices = [
  {
    country: 'Zimbabwe',
    flag: '🇿🇼',
    status: 'Headquarters',
    city: 'Harare, Zimbabwe',
    description: 'Our primary base and founding home. Serving individuals, enterprises, and government institutions nationwide.',
    image: 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Harare city skyline and buildings',
  },
  {
    country: 'Mozambique',
    flag: '🇲🇿',
    status: 'Active Region',
    city: 'Maputo, Mozambique',
    description: 'Bringing digital connectivity and smart security solutions across the border.',
    image: 'https://images.unsplash.com/photo-1589139981099-b3a4a78e8cf3?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Mozambique landscape and city',
  },
  {
    country: 'South Africa',
    flag: '🇿🇦',
    status: 'Active Region',
    city: 'Johannesburg, South Africa',
    description: 'Serving the broader Southern African market with premium technology products and services.',
    image: 'https://images.unsplash.com/photo-1577948000111-9c970dfe3743?auto=format&fit=crop&w=800&q=80',
    imageAlt: 'Johannesburg skyline South Africa',
  },
];

const contactDetails = [
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    label: 'Headquarters',
    value: 'Harare, Zimbabwe',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.76a16 16 0 0 0 6.29 6.29l1.72-1.72a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    label: 'Phone',
    value: '+263 78 000 0000',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    label: 'Email',
    value: 'info@ashaadtech.co.zw',
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
    label: 'Working Hours',
    value: 'Mon – Sat: 8:00 AM – 6:00 PM',
  },
];

const services = [
  'Digital Security (CCTV)',
  'Networking Solutions',
  'IT Protocols & Management',
  'Solar Systems & Power Banks',
  'General Enquiry',
  'Partnership / Become a Reseller',
];
---

<Layout
  title="Contact Us"
  description="Get in touch with Ashaad Intelligent Technologies. We serve Zimbabwe, Mozambique and South Africa with solar systems, IT protocols, networking and CCTV products."
>
  <!-- ===== HERO ===== -->
  <section class="contact-hero">
    <div class="hero-bg">
      <img
        src="https://images.unsplash.com/photo-1497366754035-f200581374b8?auto=format&fit=crop&w=1600&q=80"
        alt="Modern technology office"
        class="hero-bg-img"
        onerror="this.style.opacity='0';"
      />
      <div class="hero-overlay"></div>
    </div>
    <div class="container hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Contact</span>
      </div>
      <p class="section-label reveal">Get in Touch</p>
      <h1 class="display-heading hero-title reveal reveal-delay-2">
        Let's Build Something<br />
        <em>Great Together.</em>
      </h1>
      <p class="body-text hero-subtitle reveal reveal-delay-3">
        Whether you're looking for a security system, network infrastructure,<br class="br-desktop" />
        solar solution, or a strategic partnership — we're ready to help.
      </p>
    </div>
  </section>

  <!-- ===== CONTACT MAIN ===== -->
  <section class="contact-main">
    <div class="container contact-grid">

      <!-- LEFT: Info Column -->
      <div class="contact-info-col">
        <div class="info-media">
          <img
            src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80"
            alt="Ashaad team working on technology solutions"
            class="info-img"
            onerror="this.style.background='var(--navy)';"
          />
          <div class="info-img-overlay"></div>
          <div class="info-badge">
            <span class="badge-pulse"></span>
            <span>We Respond Within 24h</span>
          </div>
        </div>

        <div class="contact-details">
          <p class="section-label">Reach Us</p>
          <h2 class="display-heading info-title">
            We're Here<br />For You.
          </h2>
          <p class="body-text info-text">
            Ashaad Intelligent Technologies is committed to delivering the best service.
            Reach out for a consultation, quote, or to learn how we can serve your needs.
          </p>

          <div class="details-list">
            {contactDetails.map((d) => (
              <div class="detail-item">
                <div class="detail-icon" set:html={d.icon} />
                <div>
                  <div class="detail-label">{d.label}</div>
                  <div class="detail-value">{d.value}</div>
                </div>
              </div>
            ))}
          </div>

          <div class="info-cta-note">
            <div class="note-line"></div>
            <p class="body-text">
              <em>Professionalization &middot; Dedication &middot; Concentration</em><br />
              <span>Our enterprise spirit, every interaction.</span>
            </p>
          </div>
        </div>
      </div>

      <!-- RIGHT: Form Column -->
      <div class="contact-form-col">
        <div class="form-header">
          <p class="section-label">Send a Message</p>
          <h2 class="display-heading form-title">Start the<br />Conversation.</h2>
        </div>

        <form
          id="contact-form"
          class="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <!-- Web3Forms config -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="New Enquiry — Ashaad Intelligent Technologies" />
          <input type="hidden" name="from_name" value="Ashaad Website" />
          <input type="hidden" name="redirect" value="false" />
          <input type="checkbox" name="botcheck" style="display:none;" />

          <div class="form-field">
            <input
              type="text"
              name="name"
              id="name"
              placeholder="Full Name"
              required
              autocomplete="name"
            />
          </div>

          <div class="form-field">
            <input
              type="text"
              name="email"
              id="email"
              placeholder="Email or Phone Number"
              required
            />
          </div>

          <div class="form-field">
            <textarea
              name="message"
              id="message"
              rows="6"
              placeholder="How can we help you?"
              required
            ></textarea>
          </div>

          <div class="form-actions">
            <button type="submit" class="submit-btn" id="submit-btn">
              <span class="btn-label">Send Message</span>
              <span class="btn-loading" aria-hidden="true" style="display:none">Sending…</span>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 2L11 13"/><path d="M22 2L15 22 11 13 2 9l20-7z"/></svg>
            </button>
            <p class="form-note">Response within 24 hours. No spam.</p>
          </div>
        </form>

        <div class="form-success" id="form-success" style="display:none;">
          <div class="success-mark">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <p class="success-title">Message received.</p>
            <p class="success-sub">We'll be in touch shortly.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== REACH STRIP ===== -->
  <div class="reach-strip container">
    <span class="reach-label">We serve</span>
    {offices.map((o, i) => (
      <>
        <span class="reach-country">{o.flag} {o.country}</span>
        {i < offices.length - 1 && <span class="reach-sep">/</span>}
      </>
    ))}
    <a href="/about#regions" class="reach-link">
      Our reach
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>

  <!-- ===== PARTNER CTA ===== -->
  <section class="partner-section">
    <div class="partner-bg">
      <img
        src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=1600&q=80"
        alt="Smart security technology"
        class="partner-bg-img"
        onerror="this.style.background='var(--navy)';"
      />
      <div class="partner-overlay"></div>
    </div>
    <div class="container partner-inner">
      <div class="partner-content">
        <p class="section-label">Become a Partner</p>
        <h2 class="display-heading partner-title">
          Let Ashaad Become<br />a World Brand.
        </h2>
        <p class="body-text partner-text">
          We invite distributors, resellers, and technology partners to join us.
          Together, we will deliver the best service, the best quality —
          and build an Africa-first technology brand recognized worldwide.
        </p>
        <div class="partner-cards">
          <div class="partner-card">
            <div class="pc-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div>
              <div class="pc-title">Reseller Programme</div>
              <div class="pc-desc">Sell our products and earn competitive margins</div>
            </div>
          </div>
          <div class="partner-card">
            <div class="pc-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            </div>
            <div>
              <div class="pc-title">Regional Distributor</div>
              <div class="pc-desc">Exclusive territory rights in your region</div>
            </div>
          </div>
          <div class="partner-card">
            <div class="pc-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <div>
              <div class="pc-title">Tech Partner</div>
              <div class="pc-desc">Collaborate on installations and projects</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const successEl = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnLabel = submitBtn?.querySelector('.btn-label') as HTMLElement | null;
  const btnLoading = submitBtn?.querySelector('.btn-loading') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    // Show loading state
    if (submitBtn) submitBtn.disabled = true;
    if (btnLabel) btnLabel.style.display = 'none';
    if (btnLoading) btnLoading.style.display = 'inline';

    try {
      const data = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const result = await response.json();

      if (result.success) {
        form.style.display = 'none';
        if (successEl) successEl.style.display = 'flex';
      } else {
        throw new Error(result.message || 'Submission failed');
      }
    } catch (err) {
      // Reset button on error
      if (submitBtn) submitBtn.disabled = false;
      if (btnLabel) btnLabel.style.display = 'inline';
      if (btnLoading) btnLoading.style.display = 'none';
      alert('Something went wrong. Please try again or reach out via WhatsApp.');
    }
  });
</script>

<style>
  /* ===== HERO ===== */
  .contact-hero {
    position: relative;
    min-height: 65vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--navy);
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: brightness(0.4) saturate(0.7);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(110deg, rgba(8, 8, 15,0.92) 40%, rgba(8, 8, 15,0.3) 100%),
      linear-gradient(to bottom, transparent 50%, var(--bg) 100%);
  }

  .hero-inner {
    position: relative;
    z-index: 10;
    padding-top: 160px;
    padding-bottom: 80px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    flex: 1;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .breadcrumb a {
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: var(--accent); }

  .hero-title {
    font-size: clamp(2.5rem, 5.5vw, 4.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-subtitle {
    font-size: 1.05rem;
    max-width: 580px;
    line-height: 1.8;
  }

  .hero-strip {
    position: relative;
    z-index: 10;
    background: var(--bg-deep);
    border-top: 1px solid var(--border);
    overflow: hidden;
    padding: 0.65rem 0;
  }

  .strip-text {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    white-space: nowrap;
    animation: ticker 28s linear infinite;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-subtle);
  }

  .strip-text .dot { color: var(--accent); }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ===== CONTACT MAIN ===== */
  .contact-main {
    padding: 7rem 0;
    background: var(--bg);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 5rem;
    align-items: start;
  }

  /* Info Column */
  .info-media {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    margin-bottom: 3rem;
    border: 1px solid var(--border-light);
  }

  .info-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .info-media:hover .info-img {
    transform: scale(1.03);
  }

  .info-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 8, 15,0.7) 0%, transparent 60%);
    pointer-events: none;
  }

  .info-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(8, 8, 15,0.85);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border-light);
    padding: 0.5rem 1rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    animation: pulse-green 2s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-green {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-title {
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    margin-top: 0.5rem;
  }

  .info-text {
    font-size: 0.95rem;
    line-height: 1.8;
    max-width: 420px;
  }

  .details-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 0.5rem;
  }

  .detail-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .detail-icon {
    color: var(--accent);
    flex-shrink: 0;
    padding: 0.6rem;
    background: rgba(191, 144, 4, 0.08);
    border: 1px solid rgba(191, 144, 4, 0.15);
    margin-top: 0.1rem;
  }

  .detail-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.2rem;
  }

  .detail-value {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.5;
  }

  .info-cta-note {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-top: 1rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
  }

  .note-line {
    display: none;
  }

  .info-cta-note p {
    font-size: 0.875rem;
    line-height: 1.7;
  }

  .info-cta-note em {
    font-style: normal;
    color: var(--accent);
    font-family: 'DM Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .info-cta-note span {
    color: var(--text-muted);
    display: block;
    margin-top: 0.25rem;
  }

  /* Form Column */
  .form-header {
    margin-bottom: 3rem;
  }

  .form-title {
    font-size: clamp(2rem, 3.5vw, 3rem);
    margin-top: 0.75rem;
    line-height: 1.05;
  }

  /* Minimal form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .form-field {
    border-bottom: 1px solid var(--border-light);
    transition: border-color 0.2s;
  }

  .form-field:first-of-type {
    border-top: 1px solid var(--border-light);
  }

  .form-field:focus-within {
    border-color: var(--accent);
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    background: transparent;
    border: none;
    color: var(--text);
    padding: 1.25rem 0;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    outline: none;
    resize: none;
    line-height: 1.6;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-subtle);
    font-size: 0.95rem;
  }

  .form-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
    background: var(--cta);
    border: none;
    padding: 1rem 2rem;
    cursor: pointer;
    transition: background 0.2s, transform 0.18s;
  }

  .submit-btn:hover:not(:disabled) {
    background: var(--cta-light);
    transform: translateY(-2px);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .form-note {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--text-subtle);
  }

  /* Form success */
  .form-success {
    display: none;
    flex-direction: row;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem;
    border: 1px solid rgba(191, 144, 4, 0.25);
    background: rgba(191, 144, 4, 0.04);
    margin-top: 1rem;
  }

  .success-mark {
    color: var(--accent);
    flex-shrink: 0;
    padding: 0.75rem;
    border: 1px solid rgba(191, 144, 4, 0.3);
  }

  .success-title {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .success-sub {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  /* ===== REACH STRIP ===== */
  .reach-strip {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding: 1.5rem 2rem;
    border-top: 1px solid var(--border);
    margin: 0 auto;
  }

  .reach-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    font-weight: 500;
