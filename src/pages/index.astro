---
import Layout from '../layouts/Layout.astro';
import { cameraProducts } from '../data/products';

const services = [
  {
    id: 'digital-security',
    iconLabel: 'Camera',
    label: 'Digital Security',
    desc: 'Advanced CCTV surveillance and intelligent security systems protecting homes, businesses and communities.',
    href: '/services#digital-security',
    image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&w=600&q=80',
    imageAlt: 'Security camera surveillance',
  },
  {
    id: 'networking',
    iconLabel: 'Network',
    label: 'Networking',
    desc: 'Enterprise-grade networking infrastructure — from structured cabling to wireless and fibre solutions.',
    href: '/services#networking',
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=600&q=80',
    imageAlt: 'Network server room cables',
  },
  {
    id: 'it-protocols',
    iconLabel: 'Code',
    label: 'IT Protocols',
    desc: 'Comprehensive IT management, server configuration, software deployment, and system integration.',
    href: '/services#it-protocols',
    image: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=600&q=80',
    imageAlt: 'IT systems and server management',
  },
  {
    id: 'solar',
    iconLabel: 'Solar',
    label: 'Solar Systems',
    desc: 'Clean, reliable solar energy and power bank solutions to keep your operations running 24/7.',
    href: '/services#solar',
    image: 'https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=600&q=80',
    imageAlt: 'Solar panels installation',
  },
];

const stats = [
  { value: '2018', label: 'Founded' },
  { value: '3+', label: 'Countries' },
  { value: '4', label: 'Core Services' },
  { value: '100%', label: 'Committed' },
];
---

<Layout title="Home" description="Ashaad Intelligent Technologies — Leading provider of solar systems, IT protocols, networking and CCTV security in Zimbabwe and beyond.">
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg">
      <video
        autoplay
        muted
        loop
        playsinline
        class="hero-bg-video"
        poster="/images/hero-image.png"
      >
        <source src="/video/security-camera-hero-video.webm" type="video/webm" />
      </video>
      <div class="hero-bg-overlay"></div>
    </div>

    <!-- Decorative grid lines -->
    <div class="hero-grid" aria-hidden="true">
      <div class="grid-line"></div>
      <div class="grid-line"></div>
      <div class="grid-line"></div>
    </div>

    <div class="hero-inner container">
      <div class="hero-content">
        <p class="section-label reveal">Est. 2018 &mdash; Zimbabwe</p>
        <h1 class="display-heading hero-title reveal reveal-delay-2">
          Bringing the<br />
          <em>Digital World</em><br />
          to Everyone.
        </h1>
        <p class="hero-subtitle body-text reveal reveal-delay-3">
          Leading provider of solar systems, IT protocols, networking<br class="br-desktop" />
          and CCTV products across Zimbabwe, Mozambique &amp; South Africa.
        </p>
        <div class="hero-actions reveal reveal-delay-4">
          <a href="/services" class="btn-primary">
            Our Services
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/about" class="btn-outline">Learn About Us</a>
        </div>
      </div>

    </div>

  </section>

  <!-- ===== CAMERA SOLUTIONS CAROUSEL ===== -->
  <section class="cameras-section">
    <div class="container">

      <!-- Header row -->
      <div class="cameras-header">
        <div class="cameras-header-left">
          <p class="section-label">Camera Solutions</p>
          <h2 class="display-heading cameras-title">
            Our Camera<br /><em>Solutions.</em>
          </h2>
        </div>
        <div class="cameras-header-right">
          <p class="body-text cameras-intro">
            We supply and install leading Hikvision and Dahua camera systems — from AI-driven
            detection to full-colour night vision. Each system is matched to your site.
          </p>
        </div>
      </div>

      <!-- Carousel -->
      <div class="carousel-wrapper">
        <div class="carousel-track" id="cameraTrack">
          {cameraProducts.map((product) => (
            <div class="camera-card">
              <div class="camera-img-wrap">
                {product.image ? (
                  <img
                    src={`/images/cameras/${product.image}`}
                    alt={product.imageAlt ?? product.name}
                    class="camera-img"
                  />
                ) : (
                  <div class="camera-img-placeholder" data-brand={product.brand}>
                    <span class="placeholder-brand">{product.brand}</span>
                  </div>
                )}
              </div>
              <div class="camera-info">
                <h3 class="camera-name">{product.name}</h3>
              </div>
              <div class="camera-card-footer">
                <a href="/contact" class="btn-enquiry">
                  Sales Enquiries
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Controls: single right arrow -->
        <div class="carousel-controls">
          <button class="carousel-btn" id="carouselNext" aria-label="Next product">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>

        <!-- View all link -->
        <div class="carousel-footer">
          <a href="/products" class="btn-outline carousel-all-link">
            View All Camera Products
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </div>
  </section>

  <script>
    const track = document.getElementById('cameraTrack') as HTMLElement;
    const cards = track?.querySelectorAll<HTMLElement>('.camera-card');
    const total = cards?.length ?? 0;
    let current = 0;

    function getCardWidth(): number {
      const card = track?.querySelector<HTMLElement>('.camera-card');
      if (!card) return 360;
      const style = window.getComputedStyle(track);
      const gap = parseInt(style.gap || style.columnGap || '0');
      return card.offsetWidth + gap;
    }

    function goTo(index: number) {
      current = index >= total ? 0 : Math.max(0, index);
      track.style.transform = `translateX(-${current * getCardWidth()}px)`;
    }

    document.getElementById('carouselNext')?.addEventListener('click', () => goTo(current + 1));

    window.addEventListener('resize', () => goTo(current));
  </script>

  <!-- ===== STATS ===== -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        {stats.map((s) => (
          <div class="stat-item">
            <div class="stat-value">{s.value}</div>
            <div class="stat-desc">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="services-section">
    <div class="container">
      <div class="services-header">
        <p class="section-label">What We Do</p>
        <h2 class="display-heading section-title">
          Four Pillars of Smart Technology
        </h2>
        <a href="/services" class="btn-outline services-cta-link">
          All Services
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <div class="services-grid">
        {services.map((service) => (
          <a href={service.href} class="service-card">
            <div class="service-card-img-wrap">
              <img
                src={service.image}
                alt={service.imageAlt}
                class="service-card-img"
                onerror="this.style.background='var(--navy)';"
              />
              <div class="service-card-img-overlay"></div>
            </div>
            <div class="service-card-body">
              <div class="service-icon-label">{service.iconLabel}</div>
              <h3 class="service-name">{service.label}</h3>
              <p class="service-desc">{service.desc}</p>
              <div class="service-arrow">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section">
    <div class="cta-bg">
      <img
        src="https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=1600&q=80"
        alt="Network infrastructure"
        class="cta-bg-img"
        onerror="this.style.background='var(--navy)';"
      />
      <div class="cta-overlay"></div>
    </div>
    <div class="container cta-inner">
      <p class="section-label">Partner With Us</p>
      <h2 class="display-heading cta-title">
        Become Part of<br />Something Bigger.
      </h2>
      <p class="body-text cta-text">
        Join Ashaad Intelligent Technologies as a partner. Together, we'll deliver the best
        service, the best quality — and help build a world-class African brand.
      </p>
      <div class="cta-actions">
        <a href="/contact" class="btn-primary">
          Get in Touch
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="/services" class="btn-outline">Explore Services</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--navy);
  }

  .hero-bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.45) saturate(0.85);
  }

  .hero-bg-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg, rgba(8, 8, 15,0.82) 35%, rgba(8, 8, 15,0.25) 100%)
      linear-gradient(to bottom, transparent 55%, var(--bg) 100%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    display: flex;
    justify-content: space-around;
  }

  .grid-line {
    width: 1px;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(11, 62, 217, 0.06), transparent);
  }

  .hero-inner {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 160px;
    padding-bottom: 140px;
    flex: 1;
    max-width: 900px
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-title {
    font-size: clamp(3rem, 6vw, 5.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
  }

  .hero-title em {
    font-style: italic;
    color: var(--accent);
  }

  .hero-subtitle {
    font-size: 1rem;
    max-width: 480px;
    line-height: 1.75;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  /* ===== STATS ===== */
  .stats-section {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    padding: 3rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }

  .stat-item {
    padding: 2rem;
    text-align: center;
    border-right: 1px solid var(--border);
    transition: background 0.25s;
  }

  .stat-item:last-child {
    border-right: none;
  }

  .stat-item:hover {
    background: rgba(0, 212, 180, 0.05);
  }

  .stat-value {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 2.75rem;
    font-weight: 900;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 0.4rem;
  }

  .stat-desc {
    font-family: 'DM Mono', monospace;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ===== SERVICES ===== */
  .services-section {
    padding: 7rem 0;
    background: var(--bg);
  }

  .services-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .section-title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-top: 0.75rem;
    font-weight: 600;
  }

  .services-cta-link {
    flex-shrink: 0;
    align-self: flex-end;
    margin-bottom: 0.25rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5px;
    background: var(--border);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    text-decoration: none;
    transition: background 0.25s, transform 0.25s;
    position: relative;
    overflow: hidden;
  }

  .service-card-img-wrap {
    position: relative;
    height: 180px;
    overflow: hidden;
  }

  .service-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.65) saturate(0.75);
    transition: filter 0.4s ease, transform 0.5s ease;
  }

  .service-card:hover .service-card-img {
    filter: brightness(0.85) saturate(1);
    transform: scale(1.06);
  }

  .service-card-img-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 8, 15,0.9) 0%, transparent 60%);
    pointer-events: none;
  }

  .service-card-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem 2rem 2rem;
    flex: 1;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .service-card:hover {
    background: #0f1c2b;
    transform: translateY(-4px);
  }

  .service-icon-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.35rem 0.75rem;
    background: rgba(0, 212, 180, 0.1);
    width: fit-content;
    border: 1px solid rgba(0, 212, 180, 0.2);
    transition: background 0.25s;
  }

  .service-card:hover .service-icon-label {
    background: rgba(0, 212, 180, 0.18);
  }

  .service-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text);
  }

  .service-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.7;
    flex: 1;
  }

  .service-arrow {
    color: var(--accent);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .service-card:hover .service-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* ===== CAMERA SOLUTIONS CAROUSEL ===== */
  .cameras-section {
    padding: 8rem 0;
    background: var(--bg-section);
    border-top: 1px solid var(--border);
  }

  .cameras-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 3.5rem;
  }

  .cameras-title {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-top: 1rem;
  }

  .cameras-title em {
    font-style: italic;
    color: var(--accent);
  }

  .cameras-header-right {
    padding-top: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .cameras-intro {
    font-size: 0.975rem;
    line-height: 1.85;
  }


  /* Carousel wrapper */
  .carousel-wrapper {
    position: relative;
  }

  .carousel-track {
    display: flex;
    gap: 1px;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    background: var(--border);
  }

  /* Individual cards */
  .camera-card {
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    flex: 0 0 calc(33.333% - 1px);
    min-width: 0;
    transition: background 0.2s;
  }

  .camera-card:hover {
    background: #0f0f1a;
  }

  .camera-img-wrap {
    aspect-ratio: 4/3;
    overflow: hidden;
    flex-shrink: 0;
  }

  .camera-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9) saturate(0.85);
    transition: filter 0.3s, transform 0.4s;
  }

  .camera-card:hover .camera-img {
    filter: brightness(1) saturate(1);
    transform: scale(1.03);
  }

  .camera-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #04091e 0%, #0d1635 100%);
  }

  .camera-img-placeholder .placeholder-brand {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: rgba(0, 212, 180, 0.2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .camera-info {
    padding: 1.25rem 1.5rem;
    flex: 1;
  }

  .camera-name {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }

  .camera-card-footer {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  .btn-enquiry {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    background: transparent;
    text-decoration: none;
    padding: 0.7rem 1.25rem;
    border: 1px solid var(--border-light);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    width: 100%;
    justify-content: center;
  }

  .btn-enquiry:hover {
    border-color: var(--cta);
    color: var(--cta);
    background: rgba(242, 12, 54, 0.06);
  }

  /* Carousel controls */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    margin-top: 1.5rem;
  }

  .carousel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border-light);
    background: transparent;
    color: var(--text);
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, color 0.2s;
  }

  .carousel-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: rgba(0, 212, 180, 0.06);
  }

  .carousel-footer {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }

  .carousel-all-link {
    min-width: 220px;
    justify-content: center;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .camera-card {
      flex: 0 0 calc(50% - 1px);
    }
  }

  @media (max-width: 768px) {
    .cameras-header {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .cameras-header-right {
      padding-top: 0;
    }

    .camera-card {
      flex: 0 0 calc(100% - 1px);
    }

    .carousel-controls {
      flex-direction: column-reverse;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  /* ===== CTA ===== */
  .cta-section {
    position: relative;
    padding: 9rem 0;
    overflow: hidden;
    margin-top: 4rem;
  }

  .cta-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .cta-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.25) saturate(0.5);
  }

  .cta-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(8, 8, 15,0.97) 40%,
      rgba(8, 8, 15,0.7) 100%
    );
  }

  .cta-inner {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 680px;
  }

  .cta-title {
    font-size: clamp(1.8rem, 3.5vw, 2.75rem);
    line-height: 1.1;
  }

  .cta-text {
    font-size: 1rem;
    max-width: 520px;
  }

  .cta-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  /* Breakpoint utilities */
  .br-desktop {
    display: block;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1100px) {
    .hero-inner {
      padding-top: 120px;
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .stat-item:nth-child(2) {
      border-right: none;
    }

    .stat-item:nth-child(1),
    .stat-item:nth-child(2) {
      border-bottom: 1px solid var(--border);
    }

    .services-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .br-desktop {
      display: none;
    }

  }

  @media (max-width: 480px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
