---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductsGrid from '../components/ProductsGrid.astro';
import ProductsCTA from '../components/ProductsCTA.astro';
---

<BaseLayout
  title="Camera Products"
  description="Browse our full range of Hikvision and Dahua camera solutions. Contact us for a tailored quote."
>
  <!-- Page hero -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-grid"></div>
    <div class="page-hero-content">
      <div class="section-label">Camera Solutions</div>
      <h1 class="page-hero-title"><span>OUR</span><br>PRODUCTS</h1>
      <p class="page-hero-sub">Hikvision and Dahua camera solutions for every application. No prices displayed — contact us for a tailored quote that fits your project and budget.</p>
    </div>
  </section>

  <ProductsCTA />
  <ProductsGrid />
  <ProductsCTA />
</BaseLayout>

<style>
  .page-hero {
    min-height: 45vh;
    display: flex;
    align-items: flex-end;
    padding: 140px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(232,119,34,0.07) 0%, transparent 60%),
      linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0d0d0d 100%);
  }

  .page-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(232,119,34,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,119,34,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .page-hero-content {
    position: relative; z-index: 2;
    max-width: 700px;
  }

  .page-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 10vw, 120px);
    line-height: 0.9;
    margin-bottom: 20px;
  }

  .page-hero-title span { color: var(--orange); }

  .page-hero-sub {
    font-size: 15px;
    color: var(--ash);
    max-width: 480px;
    line-height: 1.7;
    margin-top: 20px;
  }

  @media (max-width: 900px) {
    .page-hero { padding: 120px 24px 60px; }
  }
</style>
