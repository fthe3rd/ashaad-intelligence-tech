---
import Layout from '../layouts/Layout.astro';
import { cameraProducts, CONTACT_NUMBER } from '../data/products';

// Derive a tel: link from the contact number (strip spaces/non-digits)
const telNumber = CONTACT_NUMBER.replace(/[^\d+]/g, '');
---

<Layout
  title="Camera Products"
  description="Browse our full range of Hikvision and Dahua camera solutions. No prices displayed — contact us for a tailored quote."
>

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <div class="page-hero-bg">
      <img
        src="https://images.unsplash.com/photo-1557597774-9d273605dfa9?auto=format&fit=crop&w=1600&q=80"
        alt="Professional camera installation"
        class="page-hero-img"
        onerror="this.style.background='var(--navy)';"
      />
      <div class="page-hero-overlay"></div>
    </div>
    <div class="container page-hero-inner">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span>Products</span>
      </div>
      <p class="section-label reveal">Hikvision &amp; Dahua</p>
      <h1 class="display-heading page-title reveal reveal-delay-2">
        Camera<br />
        <em>Products.</em>
      </h1>
      <p class="page-subtitle body-text reveal reveal-delay-3">
        AI-driven detection, full-colour night vision, thermal imaging and robust storage — matched to your site and budget.
      </p>

      <!-- Contact call-out — shown once here, not per card -->
      <a href={`tel:${telNumber}`} class="hero-contact reveal reveal-delay-4">
        <span class="hero-contact-label">Call or WhatsApp</span>
        <span class="hero-contact-number">{CONTACT_NUMBER}</span>
      </a>

    </div>
  </section>

  <!-- ===== PRODUCTS GRID ===== -->
  <section class="products-section">
    <div class="container">
      <div class="products-grid">
        {cameraProducts.map((product, i) => (
          <article class="product-card">

            <!-- Image or branded placeholder -->
            <div class="product-img-wrap">
              {product.image ? (
                <img
                  src={`/images/cameras/${product.image}`}
                  alt={product.imageAlt ?? `${product.brand} ${product.name}`}
                  class="product-img"
                />
              ) : (
                <div class="product-img-placeholder" data-brand={product.brand}>
                  <span class="placeholder-brand">{product.brand}</span>
                  <span class="placeholder-category">{product.category}</span>
                </div>
              )}
              {product.badge && (
                <span class="product-badge">{product.badge}</span>
              )}
            </div>

            <!-- Card body -->
            <div class="product-body">
              <div class="product-meta">
                <span class="product-brand-label">{product.brand}</span>
                <span class="product-category-badge">{product.category}</span>
              </div>
              {product.model && <p class="product-model">{product.model}</p>}
              <h2 class="product-name">{product.name}</h2>
              <p class="product-desc">{product.description}</p>
              {product.features && product.features.length > 0 && (
                <ul class="product-features">
                  {product.features.map((f) => (
                    <li>{f}</li>
                  ))}
                </ul>
              )}
            </div>

            <!-- Card footer -->
            <div class="product-footer">
              <a href="/contact" class="btn-enquiry">
                Sales Enquiries
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>

          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="products-cta">
    <div class="container products-cta-inner">
      <div>
        <p class="section-label">Get a Quote</p>
        <h2 class="display-heading products-cta-title">Not sure which system suits your property?</h2>
        <p class="body-text products-cta-text">
          Our team will assess your site and recommend the right solution. No obligation.
        </p>
      </div>
      <div class="products-cta-actions">
        <a href="/contact" class="btn-primary">
          Request a Free Assessment
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href={`https://wa.me/${telNumber.replace('+','')}`} class="btn-outline" target="_blank" rel="noopener noreferrer">
          WhatsApp Us
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.890-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        </a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== PAGE HERO ===== */
  .page-hero {
    position: relative;
    padding: 10rem 0 5rem;
    min-height: 52vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.35) saturate(0.7);
  }

  .page-hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(8,8,15,0.5) 0%, rgba(8,8,15,0.85) 100%),
      linear-gradient(105deg, rgba(8,8,15,0.9) 40%, transparent 100%);
  }

  .page-hero-inner {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 700px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .breadcrumb a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .page-title {
    font-size: clamp(3rem, 7vw, 5.5rem);
    line-height: 1.0;
    margin-top: 0.5rem;
  }

  .page-title em {
    font-style: italic;
    color: var(--accent);
  }

  .page-subtitle {
    font-size: 1rem;
    max-width: 520px;
    line-height: 1.75;
  }

  /* Contact call-out in hero */
  .hero-contact {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    padding: 0.9rem 1.5rem;
    background: rgba(191, 144, 4, 0.1);
    border: 1px solid rgba(191, 144, 4, 0.3);
    width: fit-content;
    transition: background 0.2s, border-color 0.2s;
    margin-top: 0.25rem;
  }

  .hero-contact:hover {
    background: rgba(191, 144, 4, 0.18);
    border-color: var(--accent);
  }

  .hero-contact-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hero-contact-number {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: 0.02em;
  }


  /* ===== PRODUCTS GRID ===== */
  .products-section {
    padding: 6rem 0;
    background: var(--bg);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
  }

  /* Individual product card */
  .product-card {
    background: var(--bg-card);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: background 0.2s;
  }

  .product-card:hover {
    background: #0f0f1a;
  }

  /* Image area */
  .product-img-wrap {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.8) saturate(0.85);
    transition: filter 0.3s, transform 0.4s;
  }

  .product-card:hover .product-img {
    filter: brightness(0.95) saturate(1);
    transform: scale(1.03);
  }

  /* Branded placeholder when no image */
  .product-img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #04091e 0%, #0d1635 50%, #070b1a 100%);
    border-bottom: 1px solid var(--border-light);
  }

  .product-img-placeholder[data-brand="Hikvision"] {
    background: linear-gradient(135deg, #0a0a18 0%, #0f1630 50%, #080814 100%);
  }

  .product-img-placeholder[data-brand="Dahua"] {
    background: linear-gradient(135deg, #080f05 0%, #0f1e08 50%, #060c04 100%);
  }

  .placeholder-brand {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: rgba(191, 144, 4, 0.25);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .placeholder-category {
    font-family: 'DM Mono', monospace;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.15);
  }

  .product-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    padding: 0.25rem 0.6rem;
  }

  /* Card body */
  .product-body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.5rem 1.5rem 1rem;
    flex: 1;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .product-brand-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .product-category-badge {
    font-family: 'DM Mono', monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(191, 144, 4, 0.1);
    border: 1px solid rgba(191, 144, 4, 0.2);
    padding: 0.18rem 0.5rem;
  }

  .product-model {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    color: var(--text-subtle);
    text-transform: uppercase;
    margin-top: -0.1rem;
  }

  .product-name {
    font-family: 'Syne', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.25;
  }

  .product-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .product-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .product-features li {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    padding-left: 1.1rem;
    position: relative;
  }

  .product-features li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.95rem;
    line-height: 1.4;
  }

  /* Card footer */
  .product-footer {
    padding: 1rem 1.5rem 1.5rem;
  }

  .btn-enquiry {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'DM Mono', monospace;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    background: transparent;
    text-decoration: none;
    padding: 0.7rem 1.25rem;
    border: 1px solid var(--border-light);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    width: 100%;
    justify-content: center;
  }

  .btn-enquiry:hover {
    border-color: var(--cta);
    color: var(--cta);
    background: rgba(242, 12, 54, 0.06);
  }

  /* ===== BOTTOM CTA ===== */
  .products-cta {
    padding: 6rem 0;
    background: var(--bg-section);
    border-top: 1px solid var(--border);
  }

  .products-cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4rem;
    align-items: center;
  }

  .products-cta-title {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    margin-top: 0.75rem;
    line-height: 1.1;
  }

  .products-cta-text {
    font-size: 0.9375rem;
    margin-top: 0.75rem;
    max-width: 480px;
  }

  .products-cta-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 220px;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1200px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .products-cta-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .products-cta-actions {
      flex-direction: row;
      flex-wrap: wrap;
      min-width: 0;
    }
  }

  @media (max-width: 600px) {
    .products-grid {
      grid-template-columns: 1fr;
    }

    .hero-contact {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.35rem;
    }
  }
</style>
