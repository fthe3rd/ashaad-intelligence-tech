---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import Ticker from '../components/Ticker.astro';

const services = [
  {
    num: '01',
    id: 'digital-security',
    name: 'Digital Security',
    tagline: 'Protect What Matters Most.',
    desc: 'Our digital security division designs and installs comprehensive CCTV and access control systems for residential, commercial, and industrial clients. We supply and configure leading brands including Hikvision and Dahua, with remote monitoring capability, video analytics, and 24/7 technical support. Whether you need a single camera or a full estate surveillance solution, we deliver systems that work.',
    features: [
      'CCTV design, supply &amp; installation',
      'Video analytics &amp; AI detection',
      'Access control &amp; intercoms',
      'Remote monitoring &amp; cloud storage',
      'Alarm systems &amp; perimeter protection',
      '24/7 technical support',
    ],
    image: 'https://images.unsplash.com/photo-1557597774-9d273605dfa9?auto=format&fit=crop&w=900&q=80',
  },
  {
    num: '02',
    id: 'networking',
    name: 'Networking Solutions',
    tagline: 'Connect Your World.',
    desc: 'Reliable network infrastructure is the backbone of every modern organisation. We design, deploy, and manage structured cabling, fibre optic networks, enterprise-grade wireless, and secure WAN connectivity. From small office LANs to multi-site enterprise networks, our certified engineers deliver infrastructure built to handle today\'s workloads and tomorrow\'s growth.',
    features: [
      'Structured cabling &amp; Cat6/Cat6A',
      'Fibre optic installation &amp; termination',
      'Enterprise wireless &amp; access points',
      'Managed switches &amp; routers',
      'VoIP telephony systems',
      'Network security &amp; firewall configuration',
    ],
    image: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?auto=format&fit=crop&w=900&q=80',
  },
  {
    num: '03',
    id: 'it-protocols',
    name: 'IT Protocols',
    tagline: 'Smart Systems, Smarter Management.',
    desc: 'Our IT protocols division handles the full spectrum of server infrastructure, software deployment, and day-to-day IT management. We implement cybersecurity frameworks, set up cloud environments, manage active directory and identity services, and provide responsive helpdesk support for your team. We keep your systems running, patched, and protected — so you can focus on your business.',
    features: [
      'Server setup, configuration &amp; virtualisation',
      'Software deployment &amp; licence management',
      'Active directory &amp; identity management',
      'Cybersecurity audits &amp; hardening',
      'Cloud infrastructure (Azure / AWS / hybrid)',
      'IT helpdesk &amp; managed support',
    ],
    image: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?auto=format&fit=crop&w=900&q=80',
  },
  {
    num: '04',
    id: 'solar',
    name: 'Solar Systems &amp; Power Banks',
    tagline: 'Clean Energy, Always On.',
    desc: 'Power outages and load shedding shouldn\'t stop your operations. We design and install solar photovoltaic systems, battery storage solutions, and inverter/UPS systems that keep your business running regardless of the grid. From a home backup system to a full commercial solar installation, our energy solutions are sized to your consumption, budget, and future needs.',
    features: [
      'Solar panel supply &amp; installation',
      'Lithium &amp; lead-acid battery storage',
      'Inverter &amp; UPS system sizing',
      'Grid-tied, off-grid &amp; hybrid systems',
      'Load-shedding protection solutions',
      'System monitoring &amp; performance reporting',
    ],
    image: 'https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=900&q=80',
  },
];
---

<BaseLayout
  title="Services"
  description="Explore four core services: digital security, networking, IT protocols, and solar energy solutions across Zimbabwe, Mozambique and South Africa."
>

  <!-- Page hero -->
  <section class="page-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-grid"></div>
    <div class="page-hero-content">
      <div class="section-label">What We Offer</div>
      <h1 class="page-hero-title"><span>OUR</span><br>SERVICES</h1>
      <p class="page-hero-sub">Four core divisions delivering digital security, networking, IT infrastructure and clean solar energy across Zimbabwe, Mozambique and South Africa.</p>

      <!-- Quick nav -->
      <div class="services-nav">
        {services.map(s => (
          <a href={`#${s.id}`} class="services-nav-link">
            <span class="services-nav-num">{s.num}</span>
            <span set:html={s.name}></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Ticker -->
  <Ticker />

  <!-- Service detail sections -->
  {services.map((s, i) => (
    <section class={`service-detail ${i % 2 === 1 ? 'service-detail--reverse' : ''}`} id={s.id}>
      <div class="service-image-wrap">
        <img
          src={s.image}
          alt={s.name}
          loading="lazy"
          decoding="async"
        />
        <div class="service-num-overlay">{s.num}</div>
      </div>
      <div class="service-info">
        <div class="section-label" set:html={`Service ${s.num}`}></div>
        <h2 class="service-name" set:html={s.name}></h2>
        <p class="service-tagline" set:html={s.tagline}></p>
        <p class="service-desc">{s.desc}</p>
        <ul class="service-features">
          {s.features.map(f => (
            <li set:html={f}></li>
          ))}
        </ul>
        <a href="/contact" class="btn-primary">Request a Quote</a>
      </div>
    </section>
  ))}

  <CTASection title={"LET'S CONNECT\nYOUR WORLD"} />

</BaseLayout>

<style>
  /* ── Page Hero ───────────────────────────────── */
  .page-hero {
    min-height: 55vh;
    display: flex;
    align-items: flex-end;
    padding: 140px 48px 80px;
    position: relative;
    overflow: hidden;
  }

  .page-hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(232,119,34,0.07) 0%, transparent 60%),
      linear-gradient(135deg, #0a0a0a 0%, #1a1a1a 50%, #0d0d0d 100%);
  }

  .page-hero-grid {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(232,119,34,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232,119,34,0.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .page-hero-content {
    position: relative; z-index: 2;
    max-width: 900px;
  }

  .page-hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(52px, 10vw, 120px);
    line-height: 0.9;
    margin-bottom: 20px;
  }

  .page-hero-title span { color: var(--orange); }

  .page-hero-sub {
    font-size: 15px;
    color: var(--ash);
    max-width: 500px;
    line-height: 1.7;
    margin-top: 20px;
    margin-bottom: 48px;
  }

  /* ── Services quick nav ────────────────────────── */
  .services-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .services-nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ash);
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 8px 16px;
    transition: all 0.2s;
  }

  .services-nav-link:hover {
    color: var(--dark);
    background: var(--orange);
    border-color: var(--orange);
  }

  .services-nav-num {
    color: var(--orange);
    font-size: 9px;
    letter-spacing: 0.1em;
  }

  .services-nav-link:hover .services-nav-num { color: var(--dark); }

  /* ── Service detail ────────────────────────────── */
  .service-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 580px;
    background: var(--dark);
  }

  .service-detail:nth-child(even) {
    background: var(--charcoal);
  }

  .service-detail--reverse {
    direction: rtl;
  }

  .service-detail--reverse > * {
    direction: ltr;
  }

  .service-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .service-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s ease;
  }

  .service-detail:hover .service-image-wrap img {
    transform: scale(1.04);
  }

  .service-num-overlay {
    position: absolute;
    bottom: 24px;
    left: 24px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 80px;
    line-height: 1;
    color: rgba(232,119,34,0.18);
    pointer-events: none;
    user-select: none;
  }

  .service-info {
    padding: 64px 56px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 20px;
  }

  .service-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(40px, 4.5vw, 64px);
    line-height: 0.92;
    margin-top: 8px;
    color: var(--bone);
  }

  .service-tagline {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 16px;
    letter-spacing: 0.08em;
    color: var(--orange);
    font-weight: 600;
  }

  .service-desc {
    font-size: 14px;
    color: var(--ash);
    line-height: 1.85;
  }

  .service-features {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding-top: 20px;
  }

  .service-features li {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    letter-spacing: 0.05em;
    color: var(--bone);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .service-features li::before {
    content: '';
    display: block;
    width: 16px;
    height: 1px;
    background: var(--orange);
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .page-hero { padding: 120px 24px 60px; }
    .service-detail { grid-template-columns: 1fr; min-height: auto; direction: ltr; }
    .service-detail--reverse { direction: ltr; }
    .service-image-wrap { height: 320px; }
    .service-info { padding: 40px 24px; }
    .service-features { grid-template-columns: 1fr; }
  }
</style>
